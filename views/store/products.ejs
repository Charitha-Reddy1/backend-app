<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <h1>Products Page</h1>
    <div class="row">
     <% products.forEach(product => { %>
        <div class="box">
          <div class="img">
          <img src="<%= product.imageUrl %>" width="300px" alt="Product 1">
          </div> 
          <h2 style="color:white"><%= product.name %></h2>
          <p style="color:black"><%= product.desc %></p>
          <h4 style="color:blueviolet">$<%= product.price %></h4>

        </div>
     <% }) %>
    </div>
  </body>
</html>

<!--index.js=>storeRoute.js=>storeController.js=>products.ejs-->