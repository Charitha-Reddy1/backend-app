<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users Edit Form</title>
</head>
<body>
    <h2>Users Edit Form</h2>
    <form action="/users/<%= user._id %>/save" method="POST">
        <p><input type='text' name="name" value='<%= user.name %>'></p>
        <p><input type='text' name="email" value='<%= user.email %>'></p>
        <p><input type='password' name="pass" value='<%= user.pass %>'></p>
        <button>Save</button>
    </form>
</body>
</html>